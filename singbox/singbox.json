{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:1234",
      "secret": ""
    },
    "cache_file": {
      "enabled": true,
      "store_fakeip": true
    }
  },
  "dns": {
    "servers": [
      {
        "tag": "dns_local",
        "type": "udp",
        "server": "223.5.5.5"
      },
      {
        "tag": "dns_proxy",
        "type": "https",
        "server": "cloudflare-dns.com",
        "detour": "Proxy",
        "domain_resolver": "dns_local"
      },
      {
        "tag": "dns_direct",
        "type": "https",
        "server": "dns.alidns.com",
        "domain_resolver": "dns_local"
      },
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "clash_mode": "Direct",
        "server": "dns_direct"
      },
      {
        "clash_mode": "Global",
        "server": "fakeip"
      },
      {
        "query_type": "HTTPS",
        "action": "reject"
      },
      {
        "rule_set": [
          "fakeip_filter",
          "private_domain"
        ],
        "server": "dns_direct"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "rewrite_ttl": 1,
        "server": "fakeip"
      }
    ],
    "independent_cache": true,
    "final": "dns_proxy",
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "tun",
      "address": [
        "172.19.0.0/30",
        "fdfe:dcba:9876::0/126"
      ],
      "auto_route": true,
      "strict_route": true,
      "stack": "mixed",
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "127.0.0.1",
          "server_port": 7890
        }
      }
    },
    {
      "type": "mixed",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "Proxy",
      "interrupt_exist_connections": true,
      "outbounds": []
    },
    {
      "type": "direct",
      "tag": "Direct"
    },
    {
      "type": "selector",
      "tag": "Global",
      "outbounds": [
        "Proxy"
      ]
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": {
      "server": "dns_direct"
    },
    "final": "Proxy",
    "rules": [
      {
        "action": "sniff",
        "timeout": "500ms",
        "sniffer": [
          "http",
          "tls",
          "quic",
          "dns"
        ]
      },
      {
        "action": "hijack-dns",
        "protocol": "dns"
      },
      {
        "clash_mode": "Global",
        "outbound": "Global"
      },
      {
        "clash_mode": "Direct",
        "outbound": "Direct"
      },
      {
        "rule_set": [
          "fakeip_filter",
          "private_domain"
        ],
        "outbound": "Direct"
      },
      {
        "action": "reject",
        "rule_set": "reject_domain"
      },
      {
        "rule_set": [
          "telegram_domain",
          "google_domain",
          "ai_domain",
          "github_domain",
          "youtube_domain",
          "tiktok_domain",
          "instagram_domain",
          "twitter_domain",
          "steam_domain"
        ],
        "outbound": "Proxy"
      },
      {
        "rule_set": [
          "microsoft_domain"
        ],
        "outbound": "Direct"
      },
      {
        "rule_set": [
          "proxy_domain"
        ],
        "outbound": "Proxy"
      },
      {
        "rule_set": [
          "cn_domain"
        ],
        "outbound": "Direct"
      },
      {
        "rule_set": [
          "private_ip"
        ],
        "outbound": "Direct"
      },
      {
        "rule_set": [
          "telegram_ip",
          "google_ip"
        ],
        "outbound": "Proxy"
      },
      {
        "rule_set": [
          "cn_ip"
        ],
        "outbound": "Direct"
      }
    ],
    "rule_set": [
      {
        "tag": "fakeip_filter",
        "type": "remote",
        "url": "https://testingcf.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/fakeip-filter.srs",
        "format": "binary",
        "download_detour": "Direct"
      },
      {
        "tag": "private_ip",
        "type": "remote",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/private.srs",
        "format": "binary",
        "download_detour": "Direct"
      },
      {
        "tag": "private_domain",
